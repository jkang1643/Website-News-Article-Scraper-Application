import newspaper
from newspaper import Article
import nltk
import csv
from datetime import date
import spacy
import pandas as pd
import os

# Download necessary NLTK tokenizer
nltk.download('punkt')

# Set up date variables
today = date.today()
formatted_date = today.strftime("%B %d, %Y")
extraction_date = formatted_date

# Output file names
news_csv_file = f"News Update for {formatted_date}.csv"
topics_csv_file = f"Trending Topics for {formatted_date}.csv"

# Initialize output CSV
with open(news_csv_file, 'w', encoding='utf-8-sig', newline='') as file:
    writer = csv.writer(file)
    writer.writerow(["Title", "Summary", "Keywords", "Summary Topics", "Url", "Publish Date", "Extraction Date"])

# Initialize data containers
article_list = set()
rows = []
named_entities = []

# News sources list
news_repo_real = [
    'https://www.manifoldtimes.com',
    'https://www.marineinsight.com',
    'https://www.maritime-executive.com',
    'http://www.bunkerworld.com/',
    'https://shipandbunker.com/news',
    'https://splash247.com',
    'https://www.bunkerspot.com/latest-news',
    'https://theloadstar.com/category/news/',
    "https://smartmaritimenetwork.com/category/news/",
    "https://www.seatrade-maritime.com",
    "https://gcaptain.com",
    "https://www.freightwaves.com/american-shipper",
    "https://jpt.spe.org/latest-news",
    "https://unctad.org/publications",
    "https://www.bimco.org/news-and-trends/priority-news",
    "https://iumi.com/news/news",
    "https://cmacgm-group.com/en/news-medias",
    "https://www.imo.org/en/MediaCentre/Pages/default.aspx",
    "https://www.amsa.gov.au/news-community/news-and-media-releases",
    "https://namepa.net/news/",
    'https://www.worldoil.com',
    "https://www.tradewindsnews.com/news",
]

# Load spaCy NLP model once
nlp = spacy.load('en_core_web_sm')

# Step 1: Collect article URLs from all sources
for repo in news_repo_real:
    try:
        print(f"Scraping from {repo}")
        scraped = newspaper.build(repo, memoize_articles=False)
        for article in scraped.articles:
            article_list.add(article.url)
    except Exception as e:
        print(f"Failed to build newspaper for {repo}: {e}")

print(f"Total unique articles found: {len(article_list)}")

# Step 2: Process each article
for url in article_list:
    try:
        article = Article(url)
        article.download()
        article.parse()
        article.nlp()
    except Exception as e:
        print(f"Skipping article due to error: {url} | Error: {e}")
        continue

    title = article.title
    summary = article.summary
    keywords = article.keywords
    publishdate = article.publish_date

    # NLP analysis of summary
    summary_doc = nlp(summary)
    entities = [(ent.text, ent.label_) for ent in summary_doc.ents]
    named_entities.extend(entities)

    rows.append([title, summary, keywords, entities, url, publishdate, extraction_date])
    print(f"Processed: {title}")

# Step 3: Write all articles to CSV
with open(news_csv_file, 'a', encoding='utf-8-sig', newline='') as file:
    writer = csv.writer(file)
    writer.writerows(rows)

# Step 4: Analyze entity frequency
entity_df = pd.DataFrame(named_entities, columns=['Entity Name', 'Entity Type'])

top_entities = (
    entity_df.groupby(['Entity Name', 'Entity Type'])
    .size()
    .reset_index(name='Frequency')
    .sort_values(by='Frequency', ascending=False)
)

# Filter out noise
filtered_entities = top_entities[~top_entities['Entity Type'].isin(['DATE', 'CARDINAL', 'ORDINAL'])]
filtered_entities['Date'] = extraction_date

# Step 5: Export trending topics
filtered_entities.to_csv(topics_csv_file, encoding='utf-8-sig', index=False)

print(f"\n✅ Scraping completed.")
print(f"- Articles saved to: {news_csv_file}")
print(f"- Trending topics saved to: {topics_csv_file}")
